   model:"慈悲的差別とは、女性のコートを預かったり車の扉を開けたりするような一見親切な行動だが、その根底には「女性は守られるべき一段劣った存在である」という認識がある行動を指す。これは真の男女平等とは言い難いが、女性にとっては非常に心地よく魅力的に感じられるため、たとえフェミニズム的な思想を持つ女性であっても、このような振る舞いをする男性に惹かれてしまうという矛盾が生じる。",
   pts:"①慈悲的差別の定義（女性を劣った存在と見なす前提）②具体的な行動例の記述③矛盾点（問題視されつつも魅力的に映る理由）"},
  {s:"記述式問題",q:"記述式・問2：性的魅力の高い男性（モテる男）と低い男性（非モテ）が、同じように性差別的な言動や振る舞いをした場合、女性の認識にはどのような違いが生じると述べられていますか。「認知的フレームワーク」や「再解釈」という言葉を用いて、そのメカニズムを説明してください。",
   model:"性的魅力の高い男性の場合、女性には「魅力的な相手の差別的言動を検出できなくなる」という認知的フレームワークが働くため、その言動を「頼もしさ」や「男らしさ」として肯定的に再解釈する。一方、性的魅力の低い男性に対しては再解釈モジュールが作動せず、わずかな差別的言動にも激しい嫌悪感や怒りを抱くという非対称な違いが生じる。",
   pts:"①「認知的フレームワーク」という語の正確な使用②「再解釈」の具体的な内容③モテ・非モテの評価の非対称性"},
  {s:"記述式問題",q:"記述式・問3：ソースの筆者が結論として述べている、「モテ男」になっていく男性たちが共通して気づく「女性に対する認識」とはどのようなものですか。「やさしい非モテ」が抱きがちな幻想と比較して、簡潔に記述してください。",
   model:"モテ男になる者たちは、女性を「無謬で神聖な存在」として神格化するのをやめ、女性もまた特定の認知的フレームワークを備えた生物であるという現実に気づいている。彼らは「やさしさや誠実さを持ち続ければいつか気づいてくれる」という非モテ特有の幻想を捨て、現実直視と試行錯誤を通じて女性の性質を理解した者たちである。",
   pts:"①モテ男の女性観（認知的フレームワークを持つ生物）②非モテの幻想（やさしさへの期待）との対比③現実直視という方向性"}
];

const KEYS=["A","B","C","D"];
const TOTAL=MC.length+ESSAY.length;
let mca=new Array(MC.length).fill(null);
let esa=new Array(ESSAY.length).fill("");
let done=false;

function answered(){return mca.filter(a=>a!==null).length+esa.filter(a=>a.trim().length>10).length}

function upd(){
  const n=answered();
  const pct=Math.max(3,Math.round(n/TOTAL*100));
  document.getElementById("pf").style.width=pct+"%";
  document.getElementById("pl").textContent=n+" / "+TOTAL+" 問回答済み";
  const btn=document.getElementById("sb");
  const rem=TOTAL-n;
  btn.disabled=n<TOTAL;
  btn.textContent=n<TOTAL?"採点する（あと"+rem+"問）":"採点する ✓";
}

function build(){
  const c=document.getElementById("qc");
  c.innerHTML="";
  let ls="";
  MC.forEach((q,qi)=>{
    if(q.s!==ls){const t=document.createElement("div");t.className="stag";t.textContent=q.s;c.appendChild(t);ls=q.s;}
    const d=document.createElement("div");d.className="qcard";d.id="mc"+qi;
    d.innerHTML=`<div class="qnum">問 ${qi+1}</div><div class="qtxt">${q.q}</div><div class="opts" id="o${qi}">${q.opts.map((o,oi)=>`<div class="opt" id="o${qi}_${oi}" onclick="pick(${qi},${oi})"><span class="okey">${KEYS[oi]}</span><span class="otxt">${o}</span></div>`).join("")}</div><div class="expl" id="ex${qi}"><div class="explbl">📖 解説</div><div class="extxt">${q.exp}</div></div>`;
    c.appendChild(d);
  });
  ESSAY.forEach((q,ei)=>{
    if(q.s!==ls){const t=document.createElement("div");t.className="stag e";t.textContent=q.s;c.appendChild(t);ls=q.s;}
    const d=document.createElement("div");d.className="qcard";d.id="es"+ei;
    d.innerHTML=`<div class="qnum">記述式 問 ${ei+1}</div><div class="qtxt">${q.q}</div><textarea class="etxt" id="et${ei}" placeholder="ここに回答を記述してください..." oninput="ei_input(${ei})"></textarea><div class="enote">※10文字以上で回答済み扱い</div><button class="aibtn" id="ab${ei}" onclick="score_essay(${ei})" disabled>✦ AIに採点してもらう</button><div class="aibox" id="ar${ei}"></div>`;
    c.appendChild(d);
  });
  upd();
}

function pick(qi,oi){
  if(done)return;
  mca[qi]=oi;
  MC[qi].opts.forEach((_,i)=>document.getElementById("o"+qi+"_"+i).className="opt"+(i===oi?" sel":""));
  upd();
}

function ei_input(ei){
  esa[ei]=document.getElementById("et"+ei).value;
  document.getElementById("ab"+ei).disabled=esa[ei].trim().length<10;
  upd();
}

async function score_essay(ei){
  const ans=esa[ei].trim();
  if(!ans)return;
  const btn=document.getElementById("ab"+ei);
  const box=document.getElementById("ar"+ei);
  btn.disabled=true;
  box.className="aibox on";
  box.innerHTML='<div class="spin-wrap"><div class="spinner"></div>採点中...</div>';
  const q=ESSAY[ei];
  const prompt=`あなたは恋愛心理・女性心理の講師です。以下の記述式問題に対するクライアントの回答を採点してください。

【問題】${q.q}
【模範解答】${q.model}
【採点のポイント】${q.pts}
【クライアントの回答】${ans}

以下のJSON形式のみで返してください（バッククォートや前置き不要）：
{"grade":"S/A/B/C","score":"例：18/20点","comment":"2〜3文で具体的なフィードバック。良かった点と改善点を日本語で。"}

gradeの基準：S=模範解答と同等以上、A=主要ポイントを押さえている、B=部分的に正しいが不足あり、C=重要なポイントが欠けている`;
  try{
    const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:400,messages:[{role:"user",content:prompt}]})});
    const data=await res.json();
    const txt=data.content[0].text.trim().replace(/```json|```/g,"");
    const p=JSON.parse(txt);
    const gc={S:"bs",A:"ba",B:"bb",C:"bc"}[p.grade]||"bb";
    box.innerHTML=`<div class="aihdr"><span class="badge ${gc}">評価：${p.grade}　${p.score}</span></div><div class="aicmt">${p.comment}</div>`;
    btn.textContent="✦ 再採点する";btn.disabled=false;
  }catch(e){
    box.innerHTML='<div class="aicmt" style="color:var(--red)">エラーが発生しました。もう一度お試しください。</div>';
    btn.disabled=false;btn.textContent="✦ AIに採点してもらう";
  }
}

function submit(){
  done=true;
  let sc=0;
  MC.forEach((q,qi)=>{
    const ua=mca[qi];
    MC[qi].opts.forEach((_,oi)=>{
      const el=document.getElementById("o"+qi+"_"+oi);
      el.className="opt";
      if(oi===q.ans&&oi===ua){el.classList.add("ok");sc++;}
      else if(oi===ua){el.classList.add("ng");}
      else if(oi===q.ans){el.classList.add("sc");}
    });
    document.getElementById("ex"+qi).classList.add("on");
  });
  ESSAY.forEach((_,ei)=>document.getElementById("et"+ei).disabled=true);
  showResult(sc);
}

function showResult(sc){
  document.getElementById("qs").style.display="none";
  document.getElementById("rs").style.display="block";
  window.scrollTo(0,0);
  document.getElementById("sn").textContent=sc;
  document.getElementById("rc").style.strokeDashoffset=314*(1-sc/MC.length);
  const msgs=sc>=18?["選択式は完璧です！","記述式のAI採点も確認してみましょう。"]:sc>=14?["よく理解できています！","間違えた問題の解説をもう一度確認しましょう。"]:sc>=10?["基本は押さえています。","解説を見ながら、誤解しやすい箇所を整理しましょう。"]:["もう一度資料を読み直しましょう。","解説を参考に各概念を整理してください。"];
  document.getElementById("rm").textContent=msgs[0];
  document.getElementById("rsb").textContent=msgs[1];
  const rg=document.getElementById("rg");rg.innerHTML="";
  MC.forEach((q,qi)=>{const c=document.createElement("div");c.className="rcell";c.innerHTML=`<div class="rn">問${qi+1}</div><div class="rm">${mca[qi]===q.ans?"✅":"❌"}</div>`;rg.appendChild(c);});
  const rv=document.getElementById("rvc");rv.innerHTML=`<div style="font-size:15px;font-weight:700;margin-bottom:16px;padding:0 0 12px;border-bottom:.5px solid var(--border)">選択式：解答の見直し</div>`;
  let ls="";
  MC.forEach((q,qi)=>{
    if(q.s!==ls){const t=document.createElement("div");t.className="stag";t.textContent=q.s;rv.appendChild(t);ls=q.s;}
    const d=document.createElement("div");d.className="qcard";
    d.innerHTML=`<div class="qnum">問 ${qi+1}　${mca[qi]===q.ans?"✅ 正解":"❌ 不正解"}</div><div class="qtxt">${q.q}</div><div class="opts">${q.opts.map((o,oi)=>{let cl="";if(oi===q.ans&&oi===mca[qi])cl="ok";else if(oi===mca[qi])cl="ng";else if(oi===q.ans)cl="sc";return`<div class="opt ${cl}"><span class="okey">${KEYS[oi]}</span><span class="otxt">${o}</span></div>`;}).join("")}</div><div class="expl on"><div class="explbl">📖 解説</div><div class="extxt">${q.exp}</div></div>`;
    rv.appendChild(d);
  });
}

function retry(){
  mca=new Array(MC.length).fill(null);
  esa=new Array(ESSAY.length).fill("");
  done=false;
  document.getElementById("rs").style.display="none";
  document.getElementById("qs").style.display="block";
  window.scrollTo(0,0);
  build();
}

build();
</script>
</body>
</html>
